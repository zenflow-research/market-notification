# Copy to .env and customize. Env vars override config/default.toml and config/local.toml.
# Prefix is MN_ (Market Notification).

# DB
# MN_DB__URL=sqlite:///data/notifications.db

# Ollama / Gemma
# MN_OLLAMA__URL=http://localhost:11434
# MN_OLLAMA__GEMMA_MODEL=gemma4-zenflow-moe:latest

# gemini-rr
# MN_GEMINI_RR__BINARY=C:/Users/user/bin/gemini-rr.cmd
# MN_GEMINI_RR__DEFAULT_TIMEOUT_S=600

# Paths
# MN_PATHS__PDF_DUMP_ROOT=D:/Notification Dump
# MN_PATHS__LOG_DIR=G:/market_notification/logs
# MN_PATHS__BRAIN_SCREENER_ESSENTIAL_DB=G:/brain/screener_essential.db
# MN_PATHS__SCREENER_ORIGINAL_ROOT=G:/Screener_original

# Poller
# MN_POLLER__INTERVAL_S=60
# MN_POLLER__WINDOW_24X7=true

# Pipeline
# MN_PIPELINE__SLA_CLASSIFY_MINUTES=5
# MN_PIPELINE__PDF_MAX_PAGES_DEFAULT=20

# Backfill (one-shot at first run; flip to false after import)
# MN_BACKFILL__BRAIN_HISTORY=true
# MN_BACKFILL__SCREENER_ORIGINAL_HISTORY=true

# UI
# MN_UI__PORT=8501

# Health endpoint
# MN_HEALTH__PORT=8502

# Debug logging
# MN_DEBUG=0
